KEYCARD_URL=https://your-zone.keycard.cloud
KEYCARD_RESOURCE_ID=https://your-zone.keycard.cloud/mcp
PORT=8000

# The server's application credential authenticates the token exchange. Do not commit it
# here: supply KEYCARD_CLIENT_ID and KEYCARD_CLIENT_SECRET via the environment (e.g.
# `keycard run` or your deployment's secret store).
