# Runtime config for the Databricks MCP server.
# Copy to .env and fill in.

KEYCARD_URL=https://<your-zone-id>.keycard.cloud

# Base URL the MCP client (Claude/Cursor) uses to reach this server. For local
# use this is localhost; set it to the public URL only if you host the server
# remotely. Must end with a trailing slash.
MCP_SERVER_URL=http://localhost:8000/

PORT=8000

# Databricks workspace host. The brokered token is sent as a Bearer to
# {DATABRICKS_HOST}/api/2.0/clusters/list.
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com

# KEYCARD_CLIENT_ID and KEYCARD_CLIENT_SECRET are NOT set here. `keycard run`
# brokers them from the zone vault into the process environment at startup.
