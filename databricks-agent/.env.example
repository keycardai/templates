# Runtime config for the Databricks MCP server.
# Copy to .env and fill in.

KEYCARD_URL=https://<your-zone-id>.keycard.cloud

# Base URL the MCP client (Claude/Cursor) uses to reach this server, and the
# single source of truth for the bind port (derived from this URL's port). For
# local use this is localhost; set it to the public URL only if you host the
# server remotely. Must end with a trailing slash. The advertised URL and the
# bind port must agree, otherwise MCP auth fails with an invalid audience.
MCP_SERVER_URL=http://localhost:8000/

# Databricks workspace host ONLY (no API path). Each tool appends its own
# /api/2.x/... route. The brokered token is sent as a Bearer to these routes.
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com

# Authorization toggle:
#   true  — the server verifies each tool's required scope on the caller token;
#           a missing scope returns insufficient_scope.
#   false — server scope checks are bypassed; Keycard's delegation policy
#           authorizes the token exchange instead.
ENFORCE_TOOL_SCOPES=true

# On-demand authorization-code flow toggle:
#   false — (default) tools surface the raw token-exchange error when the user
#           has no delegated grant for a resource.
#   true  — a failed exchange returns an authorization_required error pointing
#           at the `authorize` tool, which mints a Keycard /authorize link for
#           the resource. Approving it stores the grant; the retried tool then
#           succeeds. Requires the server's application to have
#           <MCP_SERVER_URL>oauth/callback registered as a redirect_uri and to
#           allow the authorization_code grant.
ENABLE_AUTHORIZATION_FLOW=false

# Optional defaults the SQL/Genie tools fall back to when the caller omits them.
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_GENIE_SPACE_ID=

# KEYCARD_CLIENT_ID and KEYCARD_CLIENT_SECRET are NOT set here. `keycard run`
# brokers them from the zone vault into the process environment at startup.
