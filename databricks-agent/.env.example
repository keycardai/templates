# Runtime config for the Databricks MCP server.
# Copy to .env and fill in.

KEYCARD_URL=https://<your-zone-id>.keycard.cloud

# Base URL the MCP client (Claude/Cursor) uses to reach this server. For local
# use this is localhost; set it to the public URL only if you host the server
# remotely. Must end with a trailing slash.
MCP_SERVER_URL=http://localhost:8000/

PORT=8000

# Databricks workspace host ONLY (no API path). Each tool appends its own
# /api/2.x/... route. The brokered token is sent as a Bearer to these routes.
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com

# Authorization toggle:
#   true  — the server verifies each tool's required scope on the caller token;
#           a missing scope returns insufficient_scope.
#   false — server scope checks are bypassed; Keycard's delegation policy
#           authorizes the token exchange instead.
ENFORCE_TOOL_SCOPES=true

# Optional defaults the SQL/Genie tools fall back to when the caller omits them.
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_GENIE_SPACE_ID=

# KEYCARD_CLIENT_ID and KEYCARD_CLIENT_SECRET are NOT set here. `keycard run`
# brokers them from the zone vault into the process environment at startup.
