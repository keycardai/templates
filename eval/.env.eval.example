# Copy to .env.eval and fill in values. Never commit .env.eval.

# Service account credentials (same as CI secrets)
CI_KEYCARD_CLIENT_ID=
CI_KEYCARD_CLIENT_SECRET=
CI_KEYCARD_ENDPOINT=https://api.keycard.ai

# Persistent eval zone (recommended — avoids email verification every run).
# Create a zone once in Keycard Console, configure zone auth (no external IDP,
# no invitation required), sign up the test user once with EVAL_HEADLESS=false,
# verify the email, then set these values. The eval will reuse this zone for
# OAuth and create/delete App+Resource per run.
EVAL_ZONE_ID=
EVAL_ZONE_ISSUER_URL=

# Test user for the browser OAuth step.
# One-time setup: run once with EVAL_HEADLESS=false, sign up with this email
# on the zone sign-in page, verify the email. All subsequent runs are headless.
EVAL_TEST_USER_EMAIL=
EVAL_TEST_USER_PASSWORD=

# Claude API key for the agent step
ANTHROPIC_API_KEY=

# Set to "false" to watch the browser (useful for first-time test user setup)
EVAL_HEADLESS=true
