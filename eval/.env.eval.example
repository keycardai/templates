# Copy to .env.eval and fill in values. Never commit .env.eval.
#
# These are the only credentials that cannot be stored in Keycard vault —
# they are needed to bootstrap zone creation before keycard run has context.
# Everything else (ANTHROPIC_API_KEY, test user) goes in keycard.toml + vault.

CI_KEYCARD_CLIENT_ID=
CI_KEYCARD_CLIENT_SECRET=
CI_KEYCARD_ENDPOINT=https://api.keycard.ai

# Your Keycard organization ID (Console → Settings).
# Required for brokered-credentials templates where the agent calls keycard agent api --org.
EVAL_ORG_ID=

# Set to "false" to watch the browser (useful for first-time test user setup)
EVAL_HEADLESS=true
