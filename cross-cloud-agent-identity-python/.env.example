# Keycard zone URL (from Zone Settings in Keycard Console)
KEYCARD_ZONE_URL=https://example.keycard.cloud

# Local dev only: use client_credentials grant with client_secret_post.
# In production (Vercel / Fly), leave these unset — the server falls back to
# platform OIDC + private_key_jwt instead.
# KEYCARD_CLIENT_ID=
# KEYCARD_CLIENT_SECRET=

# Server configuration
SERVER_PORT=8050
SERVER_URL=http://localhost:8050/mcp

# Snowflake connection
SNOWFLAKE_ACCOUNT=ORGNAME-ACCTNAME
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Anthropic resource identifier (for agent-identity bootstrap)
ANTHROPIC_RESOURCE=https://api.anthropic.com

# Snowflake resource identifier
SNOWFLAKE_RESOURCE=snowflakecomputing.com

# Optional: narrow default discovery scope.
# The agent discovers all granted resources dynamically by default.
# Set these to restrict which databases/schemas are enumerated.
# SNOWFLAKE_DATABASE=MY_DB
# SNOWFLAKE_SCHEMA=PUBLIC
# SNOWFLAKE_ROLE=MY_ROLE
