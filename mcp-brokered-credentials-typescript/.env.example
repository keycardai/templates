# Runtime config for the MCP proxy itself.
# Copy to .env and fill in.

KEYCARD_URL=https://<your-zone-id>.keycard.cloud
PORT=8000

# ── Credential discovery ─────────────────────────────────────────────
#
# The proxy discovers application credentials automatically at startup.
# You do NOT need to set KEYCARD_CLIENT_ID / KEYCARD_CLIENT_SECRET here
# in most cases — the discovery logic picks the right provider:
#
#   Local (keycard run):  `keycard run` injects KEYCARD_CLIENT_ID and
#                         KEYCARD_CLIENT_SECRET from the zone vault.
#
#   Fly.io:               Auto-detected via FLY_APP_NAME. The proxy
#                         fetches a machine OIDC token from the internal
#                         metadata endpoint — no secrets needed.
#
#   EKS:                  Auto-detected via AWS_*_TOKEN_FILE env vars.
#
# To force a specific provider, set:
#   KEYCARD_APPLICATION_CREDENTIAL_TYPE=eks_workload_identity
#   KEYCARD_APPLICATION_CREDENTIAL_TYPE=fly_workload_identity
#   KEYCARD_APPLICATION_CREDENTIAL_TYPE=web_identity
