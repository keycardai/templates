# Public URL where this agent is reachable (Keycard STS must be able to GET
# AGENT_BASE_URL/.well-known/jwks.json). See README.md for how to obtain this
# via Tailscale Funnel or Fly.io.
AGENT_BASE_URL=https://your-agent.example.com

# Keycard zone URL (https://<id>.keycard.cloud for production).
KEYCARD_URL=https://ZONE_ID.keycard.cloud

# Snowflake connection settings.
# Full account identifier (e.g. "ORGNAME-ACCTNAME").
SNOWFLAKE_ACCOUNT=ORGNAME-ACCTNAME
SNOWFLAKE_USER=autonomous_agent
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_WAREHOUSE=your_warehouse
# SNOWFLAKE_ROLE=your_role

# LLM provider and model (pi-ai provider:model format).
AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-sonnet-4-20250514

# Task the agent executes on startup.
AGENT_TASK=Query Snowflake for recent data and produce a summary report.

# Port for the agent's well-known endpoint server.
PORT=9000
